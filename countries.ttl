<http://metadata.un.org/unterm/8f2da5d0-fa10-46ef-a221-d036584a97e7>
  a skos:Concept, unterm:Country ;
  dct:identifier "8f2da5d0-fa10-46ef-a221-d036584a97e7" ;
  dct:type "country" ;
