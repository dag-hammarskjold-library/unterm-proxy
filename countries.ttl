<http://metadata.un.org/unterm/8d1b6d9d-3e9c-4166-8633-cad3a91cc7a6>
  a skos:Concept, unterm:Country ;
  dct:identifier "8d1b6d9d-3e9c-4166-8633-cad3a91cc7a6" ;
  dct:type "country" ;
  dct:created "2015-05-20T12:00:31.35+00:00"^^xsd:dateTime ;
  dct:modified "2023-11-29T19:33:03.334+00:00"^^xsd:dateTime ;
  dct:creator "desalegn biru/ny/uno" ;
  dct:contributor "guillermina.ruiz-grane" ;
  skos:prefLabel "فنزويلا (جمهورية - البوليفارية)"@ar, "委内瑞拉玻利瓦尔共和国"@zh, "Venezuela (Bolivarian Republic of)"@en, "Venezuela (République bolivarienne du)"@fr, "Venezuela (República Bolivariana de)"@es, "Венесуэла (Боливарианская Республика)"@ru ;
  skos:altLabel "جمهورية فنزويلا البوليفارية"@ar, "委内瑞拉玻利瓦尔共和国"@zh, "the Bolivarian Republic of Venezuela"@en, "la République bolivarienne du Venezuela"@fr, "la República Bolivariana de Venezuela"@es, "Боливарианская Республика Венесуэла"@ru ;
  skos:definition "全国划分为21个州，2个边疆地区（亚马孙和阿马库罗三角洲边疆区)，1个首都区和1个联邦属地（由311个岛屿组成）。<br><br>"@zh, "<ul><li>For purposes other than alphabetical lists or name-plates the following form should be used: the Bolivarian Republic of Venezuela- The bolivar fuerte (locally abbreviated as BsF) was valid from 1 January 2008 to 2011. It was subdivided into 100 céntimos.- Previously up to the end of the year 2007 (as again beginning in 2012) the bolivar (with centavos) was the legal tender in Venezuela.</li><li>A letter was received on 25 October 2004 as a follow up of a letter dated 11 August 2000 from the Permanent Mission of the Bolivarian Republic of Venezuela to the United Nations reasserting that by constitutional mandate in 1999 the official name of Venezuela was changed to the Bolivarian Republic of Venezuela. \"Any subsequent mention or announcement should be called using the new name.\"</li><li>On 17 November 2004 the Protocol and Liaison Service received from the Permanent Representative of Venezuela the information that the short name of Venezuela (formerly just \"Venezuela\") had been changed to \"Venezuela (Bolivarian Republic of)\".</li></ul>"@en ;
  skos:note "新货币“强势玻利瓦尔”2008年1月1日起正式进入流通，按1:1000的比率取代原货币“玻利瓦尔”。一个“强势玻利瓦尔”等于100分（centimos）。2012年1月1日起恢复原有名称“玻利瓦尔”。"@zh, "<br>"@en ;
