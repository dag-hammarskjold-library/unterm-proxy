<http://metadata.un.org/unterm/fd428e58-b85e-4d39-81a8-896368359dd5>
  a skos:Concept, unterm:Country ;
  dct:identifier "fd428e58-b85e-4d39-81a8-896368359dd5" ;
  dct:type "country" ;
  dct:created "2015-05-20T11:58:47.54+00:00"^^xsd:dateTime ;
  dct:modified "2023-09-15T13:47:11.767+00:00"^^xsd:dateTime ;
  dct:creator "michal.ziemski" ;
  dct:contributor "amina.benser" ;
  skos:prefLabel "ليبيا"@ar, "利比亚"@zh, "Libya"@en, "Libye (la)"@fr, "Libia"@es, "Ливия"@ru ;
  skos:altLabel "دولة ليبيا"@ar, "利比亚国"@zh, "the State of Libya"@en, "l'État de Libye"@fr, "el Estado de Libia"@es, "Государство Ливия"@ru ;
  skos:definition "全国划分28个省及两个地区。"@zh ;
  skos:note "Updated as per email from Protocol of 22 Dec 2017. On 16 September 2011 the National Transitional Council requested via the Protocol and Liaison Service that the form \"Libya\" previously not in use at the UN replace both the earlier official and short forms (respectively the Socialist People's Libyan Arab Jamahiriya and Libyan Arab Jamahiriya (the))."@en, "Le 22 décembre 2017, le Service du protocole et de la liaison a transmis une note de la Mission permanente de la Libye indiquant que le nom officiel du pays serait désormais \"État de Libye\" ; toutefois, la forme courte reste inchangée et la Libye continuera d'être classée à L dans l'ordre alphabétique. </br>Le 16 septembre 2011 le Service du Protocole et de la Liaison a transmis une note du Conseil national provisoire demandant que dorénavant le nom \"Libye\" qui n'était pas employé à l'ONU remplace les formes longues et brève précédentes soit \"la Jamahiriya arabe libyenne populaire et socialiste\" et \"Jamahiriya arabe libyenne (la)\"."@fr, "DRAE: libio; tripolitano"@es ;
  unterm:status "complete" ;
