<http://metadata.un.org/unterm/d914a0dc-7cf5-41be-8170-f028f9aa9642>
  a skos:Concept, unterm:Country ;
  dct:identifier "d914a0dc-7cf5-41be-8170-f028f9aa9642" ;
  dct:type "country" ;
  dct:created "2015-05-20T12:00:42.567+00:00"^^xsd:dateTime ;
