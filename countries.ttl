<http://metadata.un.org/unterm/6b4713e7-3a00-4d48-a15f-7ff6ea495d1f>
  a skos:Concept, unterm:Country ;
  dct:identifier "6b4713e7-3a00-4d48-a15f-7ff6ea495d1f" ;
  dct:type "country" ;
  dct:created "2015-05-20T11:58:43.31+00:00"^^xsd:dateTime ;
  dct:modified "2023-11-29T19:35:27.892+00:00"^^xsd:dateTime ;
  dct:creator "catherine hatinguais/ny/uno" ;
  dct:contributor "guillermina.ruiz-grane" ;
  skos:prefLabel "بوليفيا (دولة - المتعددة القوميات)"@ar, "多民族玻利维亚国"@zh, "Bolivia (Plurinational State of)"@en, "Bolivie (État plurinational de)"@fr, "Bolivia (Estado Plurinacional de)"@es, "Боливия (Многонациональное Государство)"@ru ;
  skos:altLabel "دولة بوليفيا المتعددة القوميات"@ar, "多民族玻利维亚国"@zh, "the Plurinational State of Bolivia"@en, "l'État plurinational de Bolivie"@fr, "el Estado Plurinacional de Bolivia"@es, "Многонациональное Государство Боливия"@ru ;
  skos:definition "全国共分为九省，分别是贝尼、丘基萨卡、科恰班巴、拉巴斯、奥鲁罗、潘多、波多西、塔里哈和圣克鲁斯省。"@zh ;
  skos:note "原译“玻利维亚多民族国”，符合西文国名“Estado Plurinacional de Bolivia”。2017年7月25日按代表团要求，改用外交部译法。<br>“多民族玻利维亚国”这一译法与原文有出入，但国内官媒使用已久，为统一起见，决定按客户意见修改。"@zh, "- For purposes other than alphabetical lists or name-plates the following form should be used: the Plurinational State of Bolivia.<br>- In a letter dated 7 April 2009 the Chief of Protocol informed that a letter dated 31 March 2009 had been received from the Permanent Mission informing of the change of name."@en, "Nouveau nom transmis à l'ONU le 7 avril 2009. La Paz est le siège du gouvernement et des ambassades. Sucre est la capitale constitutionnelle."@fr, "<div>Mediante una carta enviada a la Secretaría de las Naciones Unidas, el Gobierno de Bolivia, de conformidad con el nuevo texto constitucional promulgado el 7 de febrero de 2009, decidió adoptar la nueva denominación oficial de Estado Plurinacional de Bolivia y solicitó que esta se utilizara en todos los actos públicos y privados en las relaciones internacionales y en toda la correspondencia oficial nacional e internacional de Bolivia.</div>"@es ;
