<http://metadata.un.org/unterm/c06b1507-dd6b-4d06-a8fb-fe9077b2743a>
  a skos:Concept, unterm:Country ;
  dct:identifier "c06b1507-dd6b-4d06-a8fb-fe9077b2743a" ;
  dct:type "country" ;
  dct:created "2015-05-20T11:58:55.23+00:00"^^xsd:dateTime ;
  dct:modified "2023-08-30T20:23:50.679+00:00"^^xsd:dateTime ;
  dct:creator "desalegn biru/ny/uno" ;
  dct:contributor "amina.benser" ;
  skos:prefLabel "أيرلندا"@ar, "爱尔兰"@zh, "Ireland"@en, "Irlande (l')"@fr, "Irlanda"@es, "Ирландия"@ru ;
  skos:altLabel "أيرلندا"@ar, "爱尔兰"@zh, "Ireland"@en, "l'Irlande"@fr, "Irlanda"@es, "Ирландия"@ru ;
  skos:definition "全国分为26个郡和4个郡级市，此外还有7个非郡级市，郡下设市区和镇。26个郡为卡尔洛（CARLOW）、卡范（CAVAN）、克莱尔（CLARE）、科克（CORK）、多内加尔（DONEGAL）、都柏林（DUBLIN）、戈尔韦（GALWAY）、凯里（KERRY）、基尔代尔（KILDARE）、基尔肯尼（KILKENNY）、累伊斯（LAOIS）、利屈姆（LEITRIM）、利默里克（LIMERICK）、朗福德（LONGFORD）、劳思（LOUTH）、梅奥（MAYO）、米思（MEATH）、莫内根（MONAGHAN）、奥法莱（OFFALY）、罗斯科门（ROSCOMMON）、斯来果（SLIGO）、提珀雷里（TIPPERARY）、瓦特福德（WATERFORD）、西米思（WESTMEATH）、韦克斯福德（WEXFORD）、威克洛（WICKLOW）。4个郡级市为都柏林（DUBLIN）、科克（CORK）、利默里克（LIMERICK）和瓦特福德（WATERFORD）。"@zh ;
  skos:note "It is incorrect to refer to the euro by nationality, for example as an Austrian euro or Belgian euro. However, one may refer to a country’s holdings of euro, for example euro (France) or euro (Germany).&nbsp;"@en, "DRAE: irlandés; dublinés; gaélico"@es ;
