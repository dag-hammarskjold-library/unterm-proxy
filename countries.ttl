<http://metadata.un.org/unterm/05d47d83-cd3b-4824-b823-782edafcf308>
  a skos:Concept, unterm:Country ;
  dct:identifier "05d47d83-cd3b-4824-b823-782edafcf308" ;
  dct:type "country" ;
  dct:created "2015-05-20T11:58:59.27+00:00"^^xsd:dateTime ;
  dct:modified "2023-08-30T20:02:02.669+00:00"^^xsd:dateTime ;
  dct:creator "desalegn biru/ny/uno" ;
  dct:contributor "amina.benser" ;
  skos:prefLabel "بوروندي"@ar, "布隆迪"@zh, "Burundi"@en, "Burundi (le)"@fr, "Burundi"@es, "Бурунди"@ru ;
  skos:altLabel "جمهورية بوروندي"@ar, "布隆迪共和国"@zh, "the Republic of Burundi"@en, "la République du Burundi"@fr, "la República de Burundi"@es, "Республика Бурунди"@ru ;
  skos:definition "全国划分为1个直辖市（布琼布拉市）和16个省，各省名称如下：布班扎、布琼布拉、布鲁里、坎库佐、锡比托克、基特加、卡鲁齐、卡扬扎、基隆多、马康巴、穆朗维亚、穆因加、恩戈齐、鲁塔纳、鲁伊吉、姆瓦罗。"@zh ;
  skos:note "All three forms -- Burundi, of Burundi or Burundians -- are acceptable as either the adjective or for nationality.<div><br></div><div>Capital city changed from Bujumbura to Gitega as per the Protocol and Liaison Service. Effective date: 1 April 2019.</div><div><br></div>"@en ;
