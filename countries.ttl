<http://metadata.un.org/unterm/86af548b-4937-46a5-892c-e2143400e530>
  a skos:Concept, unterm:Country ;
  dct:identifier "86af548b-4937-46a5-892c-e2143400e530" ;
  dct:type "country" ;
  dct:created "2015-05-20T11:58:42.423+00:00"^^xsd:dateTime ;
