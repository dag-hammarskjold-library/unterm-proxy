<http://metadata.un.org/unterm/8564788e-c8cf-4d6f-bf01-2776093ab382>
  a skos:Concept, unterm:Country ;
  dct:identifier "8564788e-c8cf-4d6f-bf01-2776093ab382" ;
  dct:type "country" ;
  dct:created "2015-05-20T12:00:36.123+00:00"^^xsd:dateTime ;
