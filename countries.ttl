<http://metadata.un.org/unterm/4b1118b6-67b0-4222-8408-e8a7eeb1d996>
  a skos:Concept, unterm:Country ;
  dct:identifier "4b1118b6-67b0-4222-8408-e8a7eeb1d996" ;
