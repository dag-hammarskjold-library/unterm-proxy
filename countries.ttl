<http://metadata.un.org/unterm/24e76720-cd3a-40e9-98fe-63cd5ebb7dfd>
  a skos:Concept, unterm:Country ;
  dct:identifier "24e76720-cd3a-40e9-98fe-63cd5ebb7dfd" ;
  dct:type "country" ;
  dct:created "2015-05-20T11:59:59.257+00:00"^^xsd:dateTime ;
  dct:modified "2023-08-30T20:12:20.249+00:00"^^xsd:dateTime ;
  dct:creator "william.warner" ;
  dct:contributor "amina.benser" ;
  skos:prefLabel "الجبل الأسود"@ar, "黑山"@zh, "Montenegro"@en, "Monténégro (le)"@fr, "Montenegro"@es, "Черногория"@ru ;
  skos:altLabel "الجبل الأسود"@ar, "黑山"@zh, "Montenegro"@en, "le Monténégro"@fr, "Montenegro"@es, "Черногория"@ru ;
  skos:definition "全国分为21个行政区。"@zh ;
  skos:note "前称“黑山共和国”， 2007年10月19日改称“黑山”。"@zh, "- Former formal name: the Republic of Montenegro; replaced 19 October 2007 after the adoption of a new constitution.<br>- Admitted on 28 June 2006 to the UN as the 192nd State by General Assembly resolution 60/264 of 28 June 2006 upon recommendation by Security Council resolution 1691 (2006) of 22 June 2006.<br>- The Secretary-General received a letter dated 3 June 2006 from the President of the Republic of Serbia informing him that the membership of Serbia and Montenegro in the United Nations was to be continued by the Republic of Serbia and that the name, \"<xref onclick=\"javascript:openInternalReference(this)\" class=\"label label-inverse\" ulink=\"/display/record/UNHQ/the_Republic_of_Serbia/98822dcb-0fed-4369-90cc-7d82a8a32208\">Republic of Serbia</xref>\" was henceforth to be used instead of the name \"<xref onclick=\"javascript:openInternalReference(this)\" class=\"label label-inverse\" ulink=\"/display/record/UNHQ/Serbia_and_Montenegro/0b3c64ba-d186-4140-be0d-bea8bf803d76\">Serbia and Montenegro</xref>\". The Secretary-General also received a letter dated 5 June 2006 from the President of the Republic of Montenegro requesting admission of the Republic of Montenegro to membership in the United Nations."@en, "Le nom long \"la République du Monténégro\" a été remplacé par \"le Monténégro\" suite à l'adoption de la nouvelle constitution le 19 octobre 2007."@fr, "\"República de Montenegro\" ha sido reemplazado por \"Montenegro\" tras la promulgación de la nueva Constitución el 19 de octubre de 2007."@es ;
  unterm:status "complete" ;
  unterm:distribution "public" ;
  unterm:dbName "UNHQ" ;
  unterm:space "official" ;
