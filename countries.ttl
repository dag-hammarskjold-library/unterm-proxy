<http://metadata.un.org/unterm/67e45b85-8dbb-4986-a38f-e53fe09104e7>
  a skos:Concept, unterm:Country ;
  dct:identifier "67e45b85-8dbb-4986-a38f-e53fe09104e7" ;
  dct:type "country" ;
  dct:created "2015-05-20T12:00:29.29+00:00"^^xsd:dateTime ;
  dct:modified "2023-12-20T22:21:21.395+00:00"^^xsd:dateTime ;
  dct:creator "michal.ziemski" ;
  dct:contributor "maria.barros" ;
  skos:prefLabel "رومانيا"@ar, "罗马尼亚"@zh, "Romania"@en, "Roumanie (la)"@fr, "Rumanía"@es, "Румыния"@ru ;
  skos:altLabel "رومانيا"@ar, "罗马尼亚"@zh, "Romania"@en, "la Roumanie"@fr, "Rumanía"@es, "Румыния"@ru ;
  skos:definition "全国分为1个直辖市和41个县，下设市、镇、乡。"@zh ;
  skos:note "罗马尼亚自2005年7月起实行双货币，分旧列伊（old leu; ISO货币编码: ROL / 642）和新列伊（new leu; ISO货币编码: RON / 946）。旧列伊流通至2006年12月31日。"@zh, "(1) Romania joined the European Union on 1 January 2007 and was expected to adopt the euro in 2014.(2) On 1 July 2005 Romania underwent a currency reform switching from the previous leu (ROL) to a new leu (RON). The \"old leu\" (ROL) -- also referred to as the \"third leu\" -- remained in circulation until 31 December 2006."@en, "Le nouveau leu a été introduit en 2005 mais l'ancien leu est resté en circulation pendant un certain temps."@fr, "A partir del 15 de diciembre de 2023 se comienza a usar la grafía acentuada a solicitud de la Misión Permanente de Rumanía ante las Naciones Unidas, recibida por conducto de la Oficina de Protocolo."@es, "Новый лей был введен в 2005 году."@ru ;
