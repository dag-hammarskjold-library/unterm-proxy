  dct:contributor "public.user" ;
  skos:prefLabel "البرازيل"@ar, "巴西"@zh, "Brazil"@en, "Brésil (le)"@fr, "Brasil (el)"@es, "Бразилия"@ru ;
  skos:altLabel "جمهورية البرازيل الاتحادية"@ar, "巴西联邦共和国"@zh, "the Federative Republic of Brazil"@en, "la République fédérative du Brésil"@fr, "la República Federativa del Brasil"@es, "Федеративная Республика Бразилия"@ru ;
  skos:definition "行政区划 全国共分26个州和1个联邦区。各州名称如下：阿克里，阿拉戈斯，亚马孙，阿马帕，巴伊亚，塞阿拉，圣埃斯皮里图，戈亚斯，马拉尼昂，马托格罗索，南马托格罗索，米纳斯吉拉斯，帕拉，帕拉伊巴，巴拉那，伯南布哥，皮奥伊，北里奥格朗德，南里奥格朗德，里约热内卢，朗多尼亚，罗赖马，圣卡塔琳娜，圣保罗，塞尔希培，托坎廷斯，巴西利亚联邦区。州下设市，全国共有5564个市。"@zh ;
