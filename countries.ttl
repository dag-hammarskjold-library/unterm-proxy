<http://metadata.un.org/unterm/f2b9a082-3774-496a-8532-d90f771afe7c>
  a skos:Concept, unterm:Country ;
  dct:identifier "f2b9a082-3774-496a-8532-d90f771afe7c" ;
  dct:type "country" ;
  dct:created "2015-05-20T12:00:25.407+00:00"^^xsd:dateTime ;
