<http://metadata.un.org/unterm/cf4c819e-b2ad-474d-81ce-1e47f9ce115d>
  a skos:Concept, unterm:Country ;
  dct:identifier "cf4c819e-b2ad-474d-81ce-1e47f9ce115d" ;
  dct:type "country" ;
  dct:created "2015-05-20T12:00:52.677+00:00"^^xsd:dateTime ;
  dct:modified "2023-09-15T15:20:15.489+00:00"^^xsd:dateTime ;
  dct:creator "michal.ziemski" ;
  dct:contributor "amina.benser" ;
  skos:prefLabel "السودان"@ar, "苏丹"@zh, "Sudan (the)"@en, "Soudan (le)"@fr, "Sudán (el)"@es, "Судан"@ru ;
  skos:altLabel "جمهورية السودان"@ar, "苏丹共和国"@zh, "the Republic of the Sudan"@en, "la République du Soudan"@fr, "la República del Sudán"@es, "Республика Судан"@ru ;
  skos:note "State=州，District=县。 <div>2007年1月10日开始使用镑，取代第纳尔。</div>"@zh, "<span style=\"font-size: 10.5pt; line-height: 115%; font-family: Helvetica, sans-serif; background-image: initial; background-position: initial; background-size: initial; background-repeat: initial; background-attachment: initial; background-origin: initial; background-clip: initial;\">The Egyptian pound circulated until its replacement by the first Sudanese pound in 1956, in turn replaced by the dinar (SDD) in 1992 at a rate of 1 dinar = 10 pounds. The second pound was introduced on 10 January 2007 and became the only legal tender on 1 July 2007, replacing the dinar at a rate of 1 pound = 100 dinar</span>.<p class=\"MsoNormal\"><o:p></o:p></p>"@en, "Au sujet de la monnaie: on qualifie parfois la livre soudanaise de nouvelle car au moment de son accession à l'indépendance en 1956 le pays a adopté une première livre (désormais appeléée l'ancienne) laquelle a ensuite été remplacée en 1992 par le dinar soudanais. Monnaie officielle du pays depuis le 10 janvier 2007 la nouvelle livre est devenue l'unique monnaie légale du pays le 1er juillet de la même année."@fr, "DRAE: sudanés"@es ;
