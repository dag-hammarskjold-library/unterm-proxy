<http://metadata.un.org/unterm/dd08eda8-c78a-4f4f-bd1f-8c2d1538e03d>
  a skos:Concept, unterm:Country ;
  dct:identifier "dd08eda8-c78a-4f4f-bd1f-8c2d1538e03d" ;
  dct:type "country" ;
  dct:created "2015-05-20T12:00:56.593+00:00"^^xsd:dateTime ;
  dct:modified "2023-12-19T20:37:25.677+00:00"^^xsd:dateTime ;
  dct:creator "philip.dale" ;
  dct:contributor "frances.enriquez" ;
  skos:prefLabel "جنوب السودان"@ar, "南苏丹"@zh, "South Sudan"@en, "Soudan du Sud (le)"@fr, "Sudán del Sur"@es, "Южный Судан"@ru ;
  skos:altLabel "جمهورية جنوب السودان"@ar, "南苏丹共和国"@zh, "the Republic of South Sudan"@en, "la République du Soudan du Sud"@fr, "la República de Sudán del Sur"@es, "Республика Южный Судан"@ru ;
  skos:definition "全国共划分为北加扎勒河、西加扎勒河、瓦拉卜、湖泊、团结、上尼罗河、琼格莱、东赤道、中赤道和西赤道10个州。"@zh ;
  skos:note "تم إعلان استقلال جمهورية جنوب السودان في 9 تموز/يوليو 2011، وأصبحت الدولة العضو 193 في الأمم المتحدة في 14 تموز/يوليو 2011."@ar, "2011年7月9日正式宣布独立。联合国大会于2011年7月14日接纳其为联合国会员国。"@zh, "Became independent on 9 July 2011. Admitted as a Member State by the General Assembly on 14 July 2011. On 25 September 2023, the reconstituted Transitional National Legislative Assembly passed laws on banking and financial institutions, which, inter alia, resulted in the name of the currency being changed to the South Sudan pound."@en, "Traduction adoptée à la demande de la Délégation française (11 juillet 2011). On trouve plusieurs variantes graphiques du nom de la capitale en français (Juba Jouba); la forme en vedette a reçu l'aval du Service français à New York le 8 novembre 2011."@fr, "Провозглашен независимым государством 9 июля 2011 года. 14 июля 2011 года Генеральная Ассамблея постановила принять Республику Южный Судан в члены Организации Объединенных Наций."@ru ;
  unterm:status "complete" ;
