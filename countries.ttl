<http://metadata.un.org/unterm/7cc6e8c6-538b-4e08-85b8-f77bdc964de7>
  a skos:Concept, unterm:Country ;
  dct:identifier "7cc6e8c6-538b-4e08-85b8-f77bdc964de7" ;
  dct:type "country" ;
  dct:created "2015-05-20T12:00:06.373+00:00"^^xsd:dateTime ;
  dct:modified "2024-03-12T17:23:41.775+00:00"^^xsd:dateTime ;
  dct:creator "desalegn biru/ny/uno" ;
  dct:contributor "frances.enriquez" ;
  skos:prefLabel "تشاد"@ar, "乍得"@zh, "Chad"@en, "Tchad (le)"@fr, "Chad (el)"@es, "Чад"@ru ;
  skos:altLabel "جمهورية تشاد"@ar, "乍得共和国"@zh, "the Republic of Chad"@en, "la République du Tchad"@fr, "la República del Chad"@es, "Республика Чад"@ru ;
  skos:definition "全国分为大区（Région）、省（Département）、镇（Commune）、村（Communauté Rurale）四级。2008年3月起，全国划分为22个大区（含恩贾梅纳市），下辖57个省级单位（含首都区），各省设有县级行政单位共500余个。"@zh ;
  skos:note "*全称中非金融合作法郎，由中部非洲国家银行发行，是喀麦隆、中非共和国、乍得、刚果共和国、赤道几内亚、加蓬的法定货币。"@zh, "The CFA (Coopération financière en Afrique centrale) franc is the currency issued by the Bank of Central African States (BEAC). It is legal tender in Cameroon Central African Republic Chad Congo [The Republic of] Equatorial Guinea and Gabon."@en, "Variantes orthographiques (capitale): Ndjamena; N'Djaména; Ndjaména"@fr, "Франк Африканского финансового сообщества — денежная единица ряда африканских государств."@ru ;
