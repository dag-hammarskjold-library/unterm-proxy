  dct:contributor "sara.boyes1" ;
  skos:prefLabel "غامبيا"@ar, "冈比亚"@zh, "Gambia (the)"@en, "Gambie (la)"@fr, "Gambia"@es, "Гамбия"@ru ;
  skos:altLabel "جمهورية غامبيا"@ar, "冈比亚共和国"@zh, "the Republic of the Gambia"@en, "la République de Gambie"@fr, "la República de Gambia"@es, "Республика Гамбия"@ru ;
  skos:definition "全国分为2个市（班珠尔市和卡尼芬市）和5个区（西方区、下河区、麦卡锡岛区、上河区和北岸区），区以下分35个县，村为基层单位。<div><br></div><div>原称冈比亚共和国，2015年12月10日宣布改国名为冈比亚伊斯兰共和国。</div><div><br></div>2017年2月10日，冈比亚常驻联合国代表团通知礼宾处，冈比亚国名改为冈比亚共和国。<br><br>"@zh ;
  skos:note "DRAE: gambiano"@es ;
