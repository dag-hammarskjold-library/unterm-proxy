  dct:creator "desalegn biru/ny/uno" ;
  dct:contributor "amina.benser" ;
  skos:prefLabel "الصومال"@ar, "索马里"@zh, "Somalia"@en, "Somalie (la)"@fr, "Somalia"@es, "Сомали"@ru ;
  skos:altLabel "جمهورية الصومال الفيدرالية"@ar, "索马里联邦共和国"@zh, "the Federal Republic of Somalia"@en, "la République fédérale de Somalie"@fr, "la República Federal de Somalia"@es, "Федеративная Республика Сомали"@ru ;
  skos:definition "全国分为18个州，下设87个区，区下辖镇和村。各州为：下朱巴、中朱巴、盖多、下谢贝利、中谢贝利、贝纳迪尔、拜多阿、巴科尔、希兰、加尔古杜德、穆杜格、努加尔、巴里、萨纳格、托格代尔、哈尔格萨、阿瓦达勒、苏勒。"@zh ;
  skos:note "Federal Republic of Somalia as of September 2012."@en, "Variante précédente (jusqu'en septembre 2012): la République somalienne. Variante (capitale): Muqdisho. Mogadiscio est l'ancien nom italien tandis que Muqdisho est la forme officielle en somali. Éviter Mogadishu et autres variantes orthographiques."@fr, "DRAE: somalí"@es ;
