<http://metadata.un.org/unterm/877fe7b1-e940-43c4-9197-fd6a25af17c9>
  a skos:Concept, unterm:Country ;
  dct:identifier "877fe7b1-e940-43c4-9197-fd6a25af17c9" ;
  dct:type "country" ;
  dct:created "2015-05-20T12:00:44.86+00:00"^^xsd:dateTime ;
