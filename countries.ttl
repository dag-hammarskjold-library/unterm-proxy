<http://metadata.un.org/unterm/c6788db4-2b05-4735-952c-ce7a148cb83b>
  a skos:Concept, unterm:Country ;
  dct:identifier "c6788db4-2b05-4735-952c-ce7a148cb83b" ;
  dct:type "country" ;
  dct:created "2015-05-20T11:59:04.717+00:00"^^xsd:dateTime ;
  dct:modified "2024-03-25T19:07:12.198+00:00"^^xsd:dateTime ;
  dct:creator "desalegn biru/ny/uno" ;
  dct:contributor "frances.enriquez" ;
  skos:prefLabel "النيجر"@ar, "尼日尔"@zh, "Niger (the)"@en, "Niger (le)"@fr, "Níger (el)"@es, "Нигер"@ru ;
  skos:altLabel "جمهورية النيجر"@ar, "尼日尔共和国"@zh, "the Republic of the Niger"@en, "la République du Niger"@fr, "la República del Níger"@es, "Республика Нигер"@ru ;
  skos:definition "全国划分为蒂拉贝里、多索、塔瓦、马拉迪、津德尔、阿加德兹和迪法7个大区、1个大区级市即首都尼亚美，36个省和265个镇。"@zh ;
  skos:note "*全称非洲金融共同体法郎，由西非国家中央银行发行，是贝宁、布基纳法索、科特迪瓦、几内亚比绍、马里、尼日尔、塞内加尔、多哥的法定货币。"@zh, "1. This is a case in which the same name -- the Niger -- is used for the State and for its principal river.<div>2. The CFA (Communauté financière africaine) franc is the currency issued by the Central Bank of West African States (BCEAO). It is legal tender in Benin, Burkina Faso, Côte d’lvoire, Guinea-Bissau, Mali, the Niger, Senegal and Togo.&nbsp;<br></div>"@en, "DRAE: nigerino"@es, "Франк Африканского финансового сообщества — денежная единица ряда африканских государств.<br>Ударение в назании страны и в образованных от него топонимах ставится на первый слог.<br>"@ru ;
