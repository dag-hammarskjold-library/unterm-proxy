<http://metadata.un.org/unterm/6f9c123e-4f9d-4a6a-8d06-7662b0741933>
  a skos:Concept, unterm:Country ;
  dct:identifier "6f9c123e-4f9d-4a6a-8d06-7662b0741933" ;
  dct:type "country" ;
  dct:created "2015-05-20T11:59:24.903+00:00"^^xsd:dateTime ;
  dct:modified "2025-12-03T10:54:42.167+00:00"^^xsd:dateTime ;
  dct:creator "desalegn biru/ny/uno" ;
  dct:contributor "public.user" ;
  skos:prefLabel "بنن"@ar, "贝宁"@zh, "Benin"@en, "Bénin (le)"@fr, "Benin"@es, "Бенин"@ru ;
  skos:altLabel "جمهورية بنن"@ar, "贝宁共和国"@zh, "the Republic of Benin"@en, "la République du Bénin"@fr, "la República de Benin"@es, "Республика Бенин"@ru ;
  skos:definition "全国分为省、县（市）、镇、村四级，共12个省，77个县（市）（67个县、10个市）。12个省名称为：滨海、大西洋、韦梅、莫诺、库福、高原、祖、丘陵、东加、博尔古、阿黎博里、阿塔科拉。"@zh ;
  skos:note "*全称非洲金融共同体法郎，由西非国家中央银行发行，是贝宁、布基纳法索、科特迪瓦、几内亚比绍、马里、尼日尔、塞内加尔、多哥的法定货币。"@zh, "- Cotonou is the economic capital of Benin as well as its largest city. It houses many of Benin's government and diplomatic services although the official capital is Porto-Novo which is also the seat of the Parliament. The city is best known as a major port thanks to the Autonomous Port of Cotonou.<br>- The CFA (<xref onclick=\"javascript:openInternalReference(this)\" class=\"label label-inverse\" ulink=\"/display/record/UNHQ/Communauté_financière_africaine/8672ade1-dfe1-48f8-9055-6d978d3cbe77\">Communauté financière africaine</xref>) franc is the currency issued by the <xref onclick=\"javascript:openInternalReference(this)\" class=\"label label-inverse\" ulink=\"/display/record/UNHQ/Central_Bank_of_West_African_States/80df821e-d317-431f-92ec-355a39154a30\">Central Bank of West African States</xref> (BCEAO). It is legal tender in Benin, Burkina Faso, Côte d’lvoire, Guinea-Bissau, Mali, Niger, Senegal and Togo."@en, "Porto-Novo est la capitale constitutionnelle. Cotonou est à la fois la capitale économique et le siège de nombreux services gouvernementaux et diplomatiques."@fr, "Резиденция президента и правительства — г. Котону. Франк Африканского финансового сообщества — денежная единица ряда африканских государств."@ru ;
