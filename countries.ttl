  skos:prefLabel "كوت ديفوار"@ar, "科特迪瓦"@zh, "Côte d'Ivoire"@en, "Côte d'Ivoire (la)"@fr, "Côte d’Ivoire"@es, "Кот-д’Ивуар"@ru ;
