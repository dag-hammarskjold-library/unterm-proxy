<http://metadata.un.org/unterm/b5f1558d-8825-44f1-93d5-30a34e277ddd>
  a skos:Concept, unterm:Country ;
  dct:identifier "b5f1558d-8825-44f1-93d5-30a34e277ddd" ;
  dct:type "country" ;
  dct:created "2015-05-20T11:59:18.227+00:00"^^xsd:dateTime ;
  dct:modified "2023-08-30T20:31:24.243+00:00"^^xsd:dateTime ;
  dct:creator "desalegn biru/ny/uno" ;
  dct:contributor "amina.benser" ;
  skos:prefLabel "إيطاليا"@ar, "意大利"@zh, "Italy"@en, "Italie (l')"@fr, "Italia"@es, "Италия"@ru ;
  skos:altLabel "جمهورية إيطاليا"@ar, "意大利共和国"@zh, "the Republic of Italy"@en, "la République italienne"@fr, "la República Italiana"@es, "Итальянская Республика"@ru ;
  skos:definition "全国划分为20个行政区，103个省，8101个市镇。20个行政区包括15个普通自治行政区：皮埃蒙特、伦巴第、威内托、利古里亚、艾米利亚—罗马涅、托斯卡纳、翁布里亚、拉齐奥、马尔凯、阿布鲁佐、莫利塞、坎帕尼亚、普利亚、巴西利卡塔、卡拉布里亚，以及5个特别自治行政区：瓦莱·达奥斯塔、特伦蒂诺—上阿迪杰、弗留利—威尼斯·朱利亚、西西里岛及撒丁岛。"@zh ;
  skos:note "It is incorrect to refer to the euro by nationality, for example as an Austrian euro or Belgian euro. However, one may refer to a country’s holdings of euro, for example euro (France) or euro (Germany).&nbsp;"@en, "DRAE: italiano; romano"@es ;
