  skos:prefLabel "صربيا"@ar, "塞尔维亚"@zh, "Serbia"@en, "Serbie (la)"@fr, "Serbia"@es, "Сербия"@ru ;
  skos:altLabel "جمهورية صربيا"@ar, "塞尔维亚共和国"@zh, "the Republic of Serbia"@en, "la République de Serbie"@fr, "la República de Serbia"@es, "Республика Сербия"@ru ;
  skos:note "* Codes to be voted on by the ISO.<div>- The Secretary-General received a letter dated 3 June 2006 from the President of the Republic of Serbia informing him that the membership of Serbia and Montenegro in the United Nations was to be continued by the Republic of Serbia and that the name \"Republic of Serbia\" was henceforth to be used instead of the name \"<xref ulink=\"/display/record/UNHQ/Serbia_and_Montenegro/0b3c64ba-d186-4140-be0d-bea8bf803d76\" class=\"label label-inverse\" onclick=\"javascript:openInternalReference(this)\">Serbia and Montenegro</xref>\". The Secretary-General also received a letter dated 5 June 2006 from the President of the Republic of <xref ulink=\"/display/record/UNHQ/Montenegro/24e76720-cd3a-40e9-98fe-63cd5ebb7dfd\" class=\"label label-inverse\" onclick=\"javascript:openInternalReference(this)\">Montenegro</xref> requesting admission of the Republic of Montenegro to membership in the United Nations.</div><div>- Former currency code: YUM.</div><div>- In Kosovo both the euro and the Yugoslav dinar are legal tender.</div>"@en ;
