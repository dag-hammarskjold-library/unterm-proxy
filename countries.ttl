<http://metadata.un.org/unterm/745bbc2a-fc50-4b94-bb96-2ff7ed380081>
  a skos:Concept, unterm:Country ;
  dct:identifier "745bbc2a-fc50-4b94-bb96-2ff7ed380081" ;
  dct:type "country" ;
  dct:created "2015-05-20T12:00:09.273+00:00"^^xsd:dateTime ;
